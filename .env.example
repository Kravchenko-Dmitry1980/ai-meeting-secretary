# Example development environment variables.
# Do not use these values in production as-is.
APP_NAME=AI Meeting Secretary
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/meeting_secretary
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
APP_API_KEY=example-dev-api-key-change-me
MAX_UPLOAD_SIZE_MB=100

STORAGE_PATH=storage
FFMPEG_BINARY=ffmpeg

WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

PYANNOTE_AUTH_TOKEN=
PYANNOTE_MODEL_ID=pyannote/speaker-diarization-3.1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
